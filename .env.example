# Copy this file to .env and fill in your values
# Then run: set -a && source .env && set +a (Linux/Mac)
# Or set them in your Windows environment variables

TELEGRAM_BOT_TOKEN=123456:AAH...your_bot_token_here
TELEGRAM_CHAT_ID=123456789

# Delta Exchange region: "india" or "global". Defaults to "india".
DELTA_REGION=india

# Optional — only needed for authenticated endpoints (e.g. wallet balance,
# placing orders). Leave blank for scanner-only / paper-trade mode.
DELTA_API_KEY=
DELTA_API_SECRET=
